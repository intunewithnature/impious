# Copy this to /opt/impious/deploy/.env on the server and adjust values as needed.
CADDY_EMAIL=you@example.com
LORE_DOMAIN=impious.io
GAME_DOMAIN=game.impious.io
WIKI_DOMAIN=wiki.impious.io

# Images are published to GHCR by CI; IMAGE_PREFIX should not change unless the registry moves.
IMAGE_PREFIX=ghcr.io/intunewithnature/impious

# TAG defaults to the triggering commit SHA during automated deploys.
# Override to roll back with docker compose (e.g., TAG=previous-sha).
TAG=
