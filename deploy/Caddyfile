{$LORE_DOMAIN} {
  encode zstd gzip
  handle_path /wiki* {
    reverse_proxy wiki:80
  }
  reverse_proxy lore:80
}

{$GAME_DOMAIN} {
  encode zstd gzip
  reverse_proxy game:8080
}

